# https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="..."
UPLOADTHING_SECRET_KEY="sk_live_..."

# ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬
# ―― PAYMENTS (藍新金流 NewebPay) ―――――――――――
# ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬

# https://www.newebpay.com/ (申請商家帳號後取得)
# 測試環境：https://ccore.newebpay.com/MPG/mpg_gateway
# 正式環境：https://core.newebpay.com/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID="MS12345678"
NEWEBPAY_HASH_KEY="your_hash_key_here"
NEWEBPAY_HASH_IV="your_hash_iv_here"
# "test" | "production"
NEWEBPAY_ENV="test"

# ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬
