# https://resend.com/api-keys
RESEND_API_KEY="re_..."
# 寄件人地址（需在 Resend 驗證 domain）
RESEND_FROM_EMAIL="Ashi Tea <noreply@ashi-tea.com>"

# ▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬
